# QA environment — copy to .env.qa and fill in the values from the DEDICATED
# QA Supabase project (never the production one). See qa/SETUP.md.
#
# IMPORTANT: every variable the app reads must be defined here, even the ones
# QA does not use. Next.js lets shell env win over .env.local, but any variable
# MISSING from this file silently falls back to the production value in
# .env.local. The dummies below exist to block that leak.

# Marks this env as the QA sandbox; qa-dev.sh and qa:mint refuse to run without it.
QA_ENV=1

# Real values from the QA Supabase project (Settings → API):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-QA-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-QA-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-QA-SERVICE-ROLE-KEY

# Dummies — present only so production values can never leak through:
AUTH_CALLBACK_ORIGIN=http://localhost:3100
RESEND_API_KEY=qa-dummy
CRON_SECRET=qa-dummy
NEXT_PUBLIC_VAPID_PUBLIC_KEY=qa-dummy
VAPID_PRIVATE_KEY=qa-dummy
VAPID_CONTACT_EMAIL=qa@example.com
# Empty (not a dummy value): an empty DSN keeps the GlitchTip SDK disabled.
NEXT_PUBLIC_GLITCHTIP_DSN=
