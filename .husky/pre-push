#!/bin/sh
# Require one CHANGELOG.md entry and one package.json version bump per PR:
# every pushed branch must differ from origin/main in both files. Individual
# commits within the branch are free (linters still run per commit).

MAIN_VERSION=$(git show origin/main:package.json 2>/dev/null | grep '"version"' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)

while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip deletions (local sha is all zeros) and pushes of main itself.
  case "$local_sha" in *[!0]*) ;; *) continue ;; esac
  [ "$remote_ref" = "refs/heads/main" ] && continue

  BASE=$(git merge-base "$local_sha" origin/main 2>/dev/null) || continue

  if ! git diff --name-only "$BASE" "$local_sha" | grep -qx "CHANGELOG.md"; then
    echo ""
    echo "  pre-push: this branch adds no CHANGELOG.md entry."
    echo "  Add one ## [x.y.z] section describing the PR and bump package.json once."
    echo ""
    exit 1
  fi

  PUSH_VERSION=$(git show "$local_sha":package.json 2>/dev/null | grep '"version"' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)

  if [ -n "$MAIN_VERSION" ] && [ "$MAIN_VERSION" = "$PUSH_VERSION" ]; then
    echo ""
    echo "  pre-push: package.json version was not bumped (origin/main is already $MAIN_VERSION)."
    echo "  Bump once per PR following semver: patch (bug fix), minor (new feature), major (breaking)."
    echo ""
    exit 1
  fi
done

exit 0
